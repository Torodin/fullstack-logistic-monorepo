// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  name     String?
  password String
  role     Role    @default(OPERATOR)
  events   Event[]
}

enum Role {
  OPERATOR
  SUPERVISOR
}

model Event {
  id         Int      @id @default(autoincrement())
  date       DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  shipment   Shipment @relation(fields: [shipmentId], references: [id])
  shipmentId String
  location   String
  notes      String?
}

model Shipment {
  id           String    @id @default(dbgenerated("generate_shipment_id('ENV'::text, 1::smallint, 5::smallint)"))
  origin       String
  destination  String
  addressee    String
  phone        String?
  weight       Int
  state        State     @default(CREATED)
  delivered_at DateTime?
  events       Event[]
}

enum State {
  CREATED
  IN_WAREHOUSE
  IN_TRANSIT
  IN_DELIVERY
  DELIVERED
  RETURNED
  CANCELED
}
